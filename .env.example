# Compabob — secrets and credentials.
#
# Copy this file to .env  (cp .env.example .env)  and fill in only the values
# you need. .env is git-ignored: it is never committed and never read into a
# session by the assistant. Leave unused lines blank.

# --- Web search: exa MCP --------------------------------------------------
# Needed only if you enabled the "Web search" integration.
# Get a key at https://exa.ai (there is a free tier).
# The exa MCP server reads this from your environment, so either export it in
# your shell profile, or paste the key straight into .mcp.json (also git-ignored).
EXA_API_KEY=

# --- Telegram module ------------------------------------------------------
# Needed only if you enabled the Telegram module (modules/telegram/).
# Create a bot by messaging @BotFather on Telegram; it gives you a token.
TELEGRAM_BOT_TOKEN=
# Your own Telegram numeric chat id, so the bot only ever answers you.
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_CHAT_ID=
