{
  "_comment": "Source of truth for the integration picker used by scripts/install-integrations.sh. Versions are pinned on purpose: bump them here deliberately, never use @latest, so a clone is reproducible and an upstream release cannot break a stranger's first run. Versions verified against npm and PyPI on 2026-05-20.",
  "categories": [
    {
      "id": "web",
      "label": "Web + browser (Playwright, scrapling-fetch)",
      "requires_keys": false,
      "needs": ["npx", "uvx"],
      "servers": {
        "playwright": {
          "command": "npx",
          "args": ["-y", "@playwright/mcp@0.0.75"]
        },
        "scrapling-fetch": {
          "command": "uvx",
          "args": ["scrapling-fetch-mcp@0.2.2"]
        }
      }
    },
    {
      "id": "utility",
      "label": "Utility (time, fetch)",
      "requires_keys": false,
      "needs": ["uvx"],
      "servers": {
        "time": {
          "command": "uvx",
          "args": ["mcp-server-time@2026.1.26"]
        },
        "fetch": {
          "command": "uvx",
          "args": ["mcp-server-fetch@2025.4.7"]
        }
      }
    },
    {
      "id": "search",
      "label": "Web search (exa, needs an API key)",
      "requires_keys": true,
      "needs": ["npx"],
      "env_hint": "EXA_API_KEY",
      "doc_anchor": "web-search-exa",
      "servers": {
        "exa": {
          "command": "npx",
          "args": ["-y", "exa-mcp-server@3.2.1"],
          "env": { "EXA_API_KEY": "${EXA_API_KEY}" }
        }
      }
    },
    {
      "id": "google",
      "label": "Google Workspace (Gmail, Calendar, needs OAuth)",
      "requires_keys": true,
      "doc_anchor": "google-workspace",
      "servers": {}
    }
  ]
}
