{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Direct",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/hook-session-start.sh\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/hook-inject-now.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/hooks/hook-block-dangerous.py\"" },
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/hooks/hook-comms-guard.py\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/hooks/hook-protect-secrets.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|WebFetch|WebSearch",
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/hooks/prompt-injection-defender/post-tool-defender.py\"" }
        ]
      }
    ]
  }
}
